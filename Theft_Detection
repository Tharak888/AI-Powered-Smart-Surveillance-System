class ObjectTracker:
    """
    Centroid-based multi-object tracker with loitering detection,
    theft tracking, and object protection (locking).
    """

    def __init__(self, max_disappeared=MAX_DISAPPEARED, max_distance=MAX_DISTANCE):
        self.next_object_id = 1
        self.objects      = {}   # id -> centroid
        self.disappeared  = {}   # id -> frame count
        self.bboxes       = {}
        self.classes      = {}
        self.confidences  = {}
        self.max_disappeared = max_disappeared
        self.max_distance    = max_distance

        # Loitering
        self.positions_history = defaultdict(lambda: deque(maxlen=30))
        self.stationary_time   = {}
        self.last_check_time   = {}

        # Theft (professional)
        self.object_origins       = {}
        self.first_positions      = {}
        self.theft_status         = {}
        self.pickup_time          = {}
        self.associated_person    = {}
        self.object_in_secure_zone= {}

        # Object protection
        self.locked_objects   = {}   # id -> reference bbox
        self.lock_time        = {}
        self.protection_alerts= defaultdict(int)

        # Events
        self.all_events  = []
        self.frame_stats = defaultdict(int)

    # ------------------------------------------------------------------
    def register(self, centroid, bbox, class_name, confidence):
        obj_id = self.next_object_id
        self.objects[obj_id]       = centroid
        self.bboxes[obj_id]        = bbox
        self.classes[obj_id]       = class_name
        self.confidences[obj_id]   = confidence
        self.disappeared[obj_id]   = 0
        self.stationary_time[obj_id]  = 0.0
        self.last_check_time[obj_id]  = time.time()

        self.first_positions[obj_id]       = centroid
        self.object_origins[obj_id]        = ObjectOrigin.UNKNOWN
        self.theft_status[obj_id]          = TheftStatus.MONITORING
        self.object_in_secure_zone[obj_id] = False

        self.next_object_id += 1
        return obj_id

    # ------------------------------------------------------------------
    def deregister(self, object_id):
        attrs = [
            'objects', 'disappeared', 'bboxes', 'classes', 'confidences',
            'stationary_time', 'last_check_time', 'positions_history',
            'object_origins', 'first_positions', 'theft_status',
            'pickup_time', 'associated_person', 'object_in_secure_zone',
            'locked_objects', 'lock_time', 'protection_alerts',
        ]
        for attr in attrs:
            d = getattr(self, attr)
            if object_id in d:
                del d[object_id]

    # ------------------------------------------------------------------
    def update(self, detections):
        """
        Match new detections to existing tracks using centroid distance.

        FIX 2: scipy.spatial.distance is now imported at module level,
                not inside this method (was crashing on every frame if
                scipy was missing, with no graceful message).
        """
        if not detections:
            for object_id in list(self.disappeared.keys()):
                self.disappeared[object_id] += 1
                if self.disappeared[object_id] > self.max_disappeared:
                    self.deregister(object_id)
            return self.get_tracked_objects()

        input_centroids   = np.array([d[0] for d in detections])
        input_bboxes      = [d[1] for d in detections]
        input_classes     = [d[2] for d in detections]
        input_confidences = [d[3] for d in detections]

        if not self.objects:
            for i in range(len(detections)):
                self.register(input_centroids[i], input_bboxes[i],
                              input_classes[i], input_confidences[i])
        else:
            object_ids       = list(self.objects.keys())
            object_centroids = np.array(list(self.objects.values()))

            # FIX 2: use module-level scipy_dist (imported at top)
            D    = scipy_dist.cdist(object_centroids, input_centroids)
            rows = D.min(axis=1).argsort()
            cols = D.argmin(axis=1)[rows]

            used_rows = set()
            used_cols = set()

            for row, col in zip(rows, cols):
                if row in used_rows or col in used_cols:
                    continue
                if D[row, col] > self.max_distance:
                    continue

                object_id = object_ids[row]
                self.objects[object_id]     = input_centroids[col]
                self.bboxes[object_id]      = input_bboxes[col]
                self.classes[object_id]     = input_classes[col]
                self.confidences[object_id] = input_confidences[col]
                self.disappeared[object_id] = 0
                self.positions_history[object_id].append(input_centroids[col])

                used_rows.add(row)
                used_cols.add(col)

            for row in set(range(D.shape[0])) - used_rows:
                object_id = object_ids[row]
                self.disappeared[object_id] += 1
                if self.disappeared[object_id] > self.max_disappeared:
                    self.deregister(object_id)

            for col in set(range(D.shape[1])) - used_cols:
                self.register(input_centroids[col], input_bboxes[col],
                              input_classes[col], input_confidences[col])

        return self.get_tracked_objects()

    # ------------------------------------------------------------------
    def get_tracked_objects(self):
        result = {}
        for object_id in self.objects:
            result[object_id] = {
                'centroid':    self.objects[object_id],
                'bbox':        self.bboxes[object_id],
                'class':       self.classes[object_id],
                'confidence':  self.confidences[object_id],
                'origin':      self.object_origins.get(object_id, ObjectOrigin.UNKNOWN),
                'theft_status':self.theft_status.get(object_id, TheftStatus.MONITORING),
                'in_secure_zone': self.object_in_secure_zone.get(object_id, False),
                'is_locked':   object_id in self.locked_objects,
            }
        return result

    # ------------------------------------------------------------------
    def lock_object(self, object_id):
        if object_id in self.objects:
            self.locked_objects[object_id] = self.bboxes[object_id]
            self.lock_time[object_id]      = time.time()
            return True
        return False

    def unlock_object(self, object_id):
        if object_id in self.locked_objects:
            del self.locked_objects[object_id]
            self.lock_time.pop(object_id, None)
            return True
        return False

    # ------------------------------------------------------------------
    def check_loitering(self, object_id):
        """
        Returns (is_loitering, stationary_seconds).

        FIX 4: Original MOVEMENT_THRESHOLD=50 pixels was far too coarse —
        a genuinely stationary person's YOLO centroid still jitters a few
        pixels every frame, so avg_movement for 5 consecutive frames of a
        truly still person is well under 15 px.  Using 50 meant almost nobody
        ever triggered loitering.  Threshold lowered to 15 px.
        Also changed mean → median to be robust against single-frame outliers.
        """
        if object_id not in self.positions_history:
            return False, 0.0

        current_time = time.time()

        if object_id in self.last_check_time:
            elapsed_since_check = current_time - self.last_check_time[object_id]
            if elapsed_since_check < CHECK_INTERVAL:
                return (self.stationary_time.get(object_id, 0.0) > LOITER_THRESHOLD,
                        self.stationary_time.get(object_id, 0.0))

        history = list(self.positions_history[object_id])
        if len(history) < 2:
            self.last_check_time[object_id] = current_time
            return False, 0.0

        recent = history[-5:]
        movements = [
            math.sqrt((recent[i+1][0]-recent[i][0])**2 + (recent[i+1][1]-recent[i][1])**2)
            for i in range(len(recent)-1)
        ]

        # FIX 4: use median instead of mean — robust to single-frame bbox jitter
        avg_movement = float(np.median(movements)) if movements else 0.0

        time_delta = current_time - self.last_check_time.get(object_id, current_time)

        if avg_movement < MOVEMENT_THRESHOLD:
            self.stationary_time[object_id] = self.stationary_time.get(object_id, 0.0) + time_delta
        else:
            self.stationary_time[object_id] = 0.0

        self.last_check_time[object_id] = current_time

        loiter_time = self.stationary_time.get(object_id, 0.0)
        return loiter_time > LOITER_THRESHOLD, loiter_time

