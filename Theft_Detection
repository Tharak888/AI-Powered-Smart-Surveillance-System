class TheftDetector:
    """
    Evaluates theft, loitering, restricted-area, and object-protection events.
    """

    def __init__(self, tracker: ObjectTracker, zone_manager: ZoneManager):
        self.tracker      = tracker
        self.zone_manager = zone_manager
        self.theft_events = []
        self.alert_history= []

    # ------------------------------------------------------------------
    def log_event(self, event_type, details):
        event = {
            'timestamp': datetime.now().strftime('%H:%M:%S.%f')[:-3],
            'type':      event_type,
            'details':   details,
        }
        self.theft_events.append(event)
        if ENABLE_LOGGING:
            print(f"[{event['timestamp']}] {event_type}: {details}")

    # ------------------------------------------------------------------
    def determine_object_origin(self, object_id, centroid, class_name,
                                 snapshot: dict):
        """
        Decide whether an object originated inside a secure zone or with a person.

        FIX 6: Original called self.tracker.get_tracked_objects() inside this
                method.  That method is called once per new object inside the
                main loop — passing the already-built snapshot avoids N
                redundant full dict rebuilds per frame.
        """
        if class_name == 'person':
            return

        in_secure, _ = self.zone_manager.check_in_secure_zone(centroid)

        if in_secure:
            self.tracker.object_origins[object_id]        = ObjectOrigin.SECURE_ZONE
            self.tracker.object_in_secure_zone[object_id] = True
            self.log_event("ORIGIN_DETECTED",
                           f"Object {object_id} ({class_name}) from SECURE zone")
            return

        # Check proximity to a person using the passed snapshot
        for pid, pdata in snapshot.items():
            if pdata['class'] != 'person' or pid == object_id:
                continue
            if centroid_distance(centroid, pdata['centroid']) < PICKUP_DISTANCE_THRESHOLD * 1.5:
                self.tracker.object_origins[object_id] = ObjectOrigin.WITH_PERSON
                self.log_event("ORIGIN_DETECTED",
                               f"Object {object_id} ({class_name}) with person {pid}")
                return

        self.tracker.object_origins[object_id] = ObjectOrigin.UNKNOWN

    # ------------------------------------------------------------------
    def check_person_object_interaction(self, person_id, person_centroid,
                                         snapshot: dict):
        """
        Detect when a person picks up an item from a secure zone.

        FIX 7: Original called self.tracker.get_tracked_objects() internally.
               Now accepts the already-built snapshot from the main loop.
        """
        for obj_id, obj_data in snapshot.items():
            if obj_data['origin'] != ObjectOrigin.SECURE_ZONE:
                continue
            if obj_data['theft_status'] in (TheftStatus.TAKEN,
                                             TheftStatus.THEFT_CONFIRMED):
                continue

            distance = centroid_distance(person_centroid, obj_data['centroid'])
            if distance >= PICKUP_DISTANCE_THRESHOLD:
                continue

            in_secure, _ = self.zone_manager.check_in_secure_zone(obj_data['centroid'])
            if not in_secure and self.tracker.theft_status[obj_id] == TheftStatus.MONITORING:
                self.tracker.theft_status[obj_id]       = TheftStatus.PICKED_UP
                self.tracker.pickup_time[obj_id]        = time.time()
                self.tracker.associated_person[obj_id]  = person_id
                self.tracker.object_in_secure_zone[obj_id] = False
                self.log_event("PICKUP_DETECTED",
                               f"Person {person_id} picked up Object {obj_id}")
                return obj_id, True

        return None, False

    # ------------------------------------------------------------------
    def check_item_returned(self, object_id, centroid):
        in_secure, _ = self.zone_manager.check_in_secure_zone(centroid)
        if in_secure:
            if self.tracker.theft_status[object_id] in (TheftStatus.PICKED_UP,
                                                          TheftStatus.TAKEN):
                self.tracker.theft_status[object_id]          = TheftStatus.MONITORING
                self.tracker.object_in_secure_zone[object_id] = True
                self.tracker.pickup_time.pop(object_id, None)
                self.tracker.associated_person.pop(object_id, None)
                self.log_event("ITEM_RETURNED",
                               f"Object {object_id} returned to secure zone")
                return True
        return False

    # ------------------------------------------------------------------
    def check_theft_confirmation(self, person_id, person_centroid):
        """
        Confirm theft when person carrying an item enters the exit zone.

        FIX 3: Original only checked TheftStatus.TAKEN.  If a person moves
               quickly toward the exit before TIME_BEFORE_ALERT elapses the
               status is still PICKED_UP — theft would be missed.  Now checks
               both PICKED_UP and TAKEN.
        """
        in_exit, _ = self.zone_manager.check_in_exit_zone(person_centroid)
        if not in_exit:
            return None

        for obj_id, assoc_person in self.tracker.associated_person.items():
            if assoc_person != person_id:
                continue
            # FIX 3: was only TheftStatus.TAKEN — now also catches PICKED_UP
            if self.tracker.theft_status[obj_id] in (TheftStatus.PICKED_UP,
                                                      TheftStatus.TAKEN):
                self.tracker.theft_status[obj_id] = TheftStatus.THEFT_CONFIRMED
                self.log_event("THEFT_CONFIRMED",
                               f"Person {person_id} exited with Object {obj_id}")
                return obj_id

        return None

    # ------------------------------------------------------------------
    def update_time_based_status(self):
        """Promote PICKED_UP → TAKEN after TIME_BEFORE_ALERT seconds."""
        current_time = time.time()
        for obj_id, pickup_time in list(self.tracker.pickup_time.items()):
            if (self.tracker.theft_status.get(obj_id) == TheftStatus.PICKED_UP
                    and current_time - pickup_time > TIME_BEFORE_ALERT):
                self.tracker.theft_status[obj_id] = TheftStatus.TAKEN
                self.log_event("STATUS_UPDATE",
                               f"Object {obj_id} marked as TAKEN")

    # ------------------------------------------------------------------
    @staticmethod
    def calculate_suspicion_score(is_loitering, loiter_time, in_restricted):
        score = 0
        if is_loitering:
            score += min(50, (loiter_time / LOITER_THRESHOLD) * 30)
        if in_restricted:
            score += 30
        return min(100, score)

    # ------------------------------------------------------------------
    def check_protected_object(self, object_id, centroid):
        """
        Alert when a locked object has moved significantly AND a person is nearby.

        FIX 5: Original accepted centroid but never used it — it re-read
               self.tracker.bboxes and rebuilt objects from get_tracked_objects().
               Now uses centroid directly for the person-proximity check and
               accesses the snapshot from within the method via tracker state.
        """
        if object_id not in self.tracker.locked_objects:
            return False

        ref_box     = self.tracker.locked_objects[object_id]
        current_box = self.tracker.bboxes[object_id]
        iou         = calculate_iou(ref_box, current_box)

        if iou >= 0.3:
            # Object still in place — reset counter
            self.tracker.protection_alerts[object_id] = 0
            return False

        self.tracker.protection_alerts[object_id] += 1

        if self.tracker.protection_alerts[object_id] <= 5:
            return False  # Need sustained displacement before alerting

        # FIX 5: use the centroid param passed in (was unused before)
        for pid in list(self.tracker.objects.keys()):
            if self.tracker.classes.get(pid) != 'person':
                continue
            if centroid_distance(centroid, self.tracker.objects[pid]) < PICKUP_DISTANCE_THRESHOLD:
                return True  # Protection alert!

        return False

# ============================================================================
# MAIN
# ============================================================================

def main():
    print("\n" + "=" * 80)
    print("╔" + "=" * 78 + "╗")
    print("║" + "ULTIMATE THEFT DETECTION SYSTEM v2.1 (FIXED)".center(78) + "║")
    print("║" + "Multi-Strategy Hybrid Approach".center(78) + "║")
    print("╚" + "=" * 78 + "╝")
    print("=" * 80)

    print("\nLoading YOLO model …")
    try:
        model = YOLO(MODEL_SIZE)
        print("✓ YOLO loaded\n")
    except Exception as exc:
        print(f"❌ Could not load model: {exc}")
        return

    tracker        = ObjectTracker()
    zone_manager   = ZoneManager()
    theft_detector = TheftDetector(tracker, zone_manager)

    print("📹 Opening camera …")
    camera = cv2.VideoCapture(CAMERA_INDEX)
    if not camera.isOpened():
        print("❌ Cannot access camera!")
        return
    camera.set(cv2.CAP_PROP_FRAME_WIDTH,  CAMERA_WIDTH)
    camera.set(cv2.CAP_PROP_FRAME_HEIGHT, CAMERA_HEIGHT)
    print("✓ Camera opened\n")

    # Zone drawing state
    drawing_zone       = False
    current_zone_type  = ZoneType.SECURE
    current_zone_points= []
    mouse_position     = [0, 0]

    # FIX 8: explicit nonlocal for current_zone_points ensures closure is
    #         unambiguous even if the list is ever reassigned inside the callback
    def mouse_callback(event, x, y, flags, param):
        nonlocal current_zone_points, drawing_zone, mouse_position
        mouse_position[0] = x
        mouse_position[1] = y
        if drawing_zone and event == cv2.EVENT_LBUTTONDOWN:
            current_zone_points.append([x, y])
            print(f"  Point added: ({x}, {y})")

    cv2.namedWindow('Ultimate Theft Detection System')
    cv2.setMouseCallback('Ultimate Theft Detection System', mouse_callback)

    frame_count         = 0
    total_thefts        = 0
    total_loitering     = 0
    total_restricted    = 0
    total_suspicious    = 0
    total_protection    = 0
    alert_active        = False
    alert_message       = ""
    alert_time          = 0.0
    previous_object_ids = set()

    print("=" * 80)
    print("CONTROLS:")
    print("  o = Draw SECURE zone (green)  |  e = Draw EXIT zone (red)")
    print("  z = Draw RESTRICTED zone      |  l = Lock object under cursor")
    print("  u = Unlock all locked objects |  c = Clear all zones")
    print("  s = Save zones                |  q = Quit")
    print("=" * 80 + "\n")

    # ------------------------------------------------------------------ #
    #  Helper: start / finish a zone drawing                               #
    # ------------------------------------------------------------------ #
    def _toggle_zone(zone_type, color_name):
        """
        FIX 9: If we're already drawing a *different* zone type we finish
               that zone first.  Original code would abandon it silently.
        """
        nonlocal drawing_zone, current_zone_type, current_zone_points

        if drawing_zone:
            # Finish whatever zone was in progress
            if len(current_zone_points) >= 3:
                zone_manager.add_zone(current_zone_points,
                                      current_zone_type)
                print(f"✓ {current_zone_type.value.upper()} zone saved")
            current_zone_points = []

            if current_zone_type == zone_type:
                # Same key pressed twice → just finish
                drawing_zone = False
                return

        # Start new zone
        drawing_zone      = True
        current_zone_type = zone_type
        current_zone_points = []
        print(f"\n📍 Drawing {color_name} zone — click points, press key again to finish")

    # ------------------------------------------------------------------ main loop
    while True:
        ret, frame = camera.read()
        if not ret:
            print("⚠ Frame capture failed — retrying …")
            time.sleep(0.05)
            continue

        frame_count += 1
        frame = cv2.flip(frame, 1)
        image_height, image_width = frame.shape[:2]

        # ---- YOLO detection ----
        results = model(frame, conf=CONFIDENCE_THRESHOLD,
                        iou=IOU_THRESHOLD, verbose=False)
        detections = []
        for result in results:
            for box in result.boxes:
                cls = int(box.cls[0])
                if cls not in TRACKED_CLASSES:
                    continue
                x1, y1, x2, y2 = box.xyxy[0].cpu().numpy()
                conf       = float(box.conf[0])
                cx, cy     = int((x1 + x2) / 2), int((y1 + y2) / 2)
                bbox       = (int(x1), int(y1), int(x2), int(y2))
                detections.append(((cx, cy), bbox, TRACKED_CLASSES[cls], conf))

        # ---- Update tracker ----
        tracked_objects     = tracker.update(detections)
        current_object_ids  = set(tracked_objects.keys())
        new_object_ids      = current_object_ids - previous_object_ids
        previous_object_ids = current_object_ids

        # ---- Determine origin for newly appeared objects ----
        for obj_id in new_object_ids:
            if obj_id in tracked_objects:
                obj_data = tracked_objects[obj_id]
                # FIX 6: pass snapshot instead of letting the method call
                #         get_tracked_objects() itself
                theft_detector.determine_object_origin(
                    obj_id, obj_data['centroid'], obj_data['class'],
                    tracked_objects)

        theft_detector.update_time_based_status()

        # ---- Per-object analysis ----
        for obj_id, obj_data in tracked_objects.items():
            centroid     = obj_data['centroid']
            bbox         = obj_data['bbox']
            class_name   = obj_data['class']
            confidence   = obj_data['confidence']
            origin       = obj_data['origin']
            theft_status = obj_data['theft_status']
            is_locked    = obj_data['is_locked']

            # Return check
            if theft_status in (TheftStatus.PICKED_UP, TheftStatus.TAKEN):
                theft_detector.check_item_returned(obj_id, centroid)

            if class_name == 'person':
                # Theft detection (FIX 7: pass snapshot)
                theft_detector.check_person_object_interaction(
                    obj_id, centroid, tracked_objects)

                stolen_obj_id = theft_detector.check_theft_confirmation(
                    obj_id, centroid)
                if stolen_obj_id is not None:
                    total_thefts += 1
                    alert_active  = True
                    alert_message = f"THEFT!  Person:{obj_id}  Item:{stolen_obj_id}"
                    alert_time    = time.time()
                    play_alert_sound(1200, 500)
                    print(f"\n{'='*60}\n🚨 THEFT CONFIRMED!"
                          f"\n   Person:{obj_id}  Item:{stolen_obj_id}"
                          f"\n{'='*60}\n")

                # Behavioral checks
                is_loitering,  loiter_time  = tracker.check_loitering(obj_id)
                in_restricted, _            = zone_manager.check_in_restricted_zone(centroid)
                suspicion_score             = TheftDetector.calculate_suspicion_score(
                                                is_loitering, loiter_time, in_restricted)

                if is_loitering and not alert_active:
                    total_loitering += 1
                    alert_active     = True
                    alert_message    = f"LOITERING  ID:{obj_id}  ({loiter_time:.0f}s)"
                    alert_time       = time.time()
                    play_alert_sound(900, 300)

                if in_restricted and not alert_active:
                    total_restricted += 1
                    alert_active      = True
                    alert_message     = f"RESTRICTED AREA  ID:{obj_id}"
                    alert_time        = time.time()
                    play_alert_sound(1400, 300)

                if suspicion_score > 70 and not alert_active:
                    total_suspicious += 1
                    alert_active      = True
                    alert_message     = f"SUSPICIOUS  ID:{obj_id}  ({int(suspicion_score)}%)"
                    alert_time        = time.time()
                    play_alert_sound(1000, 400)

            # Object protection (FIX 5: centroid now used inside method)
            if is_locked:
                if theft_detector.check_protected_object(obj_id, centroid) and not alert_active:
                    total_protection += 1
                    alert_active      = True
                    alert_message     = f"LOCKED OBJECT MOVED  ID:{obj_id}"
                    alert_time        = time.time()
                    play_alert_sound(1600, 400)

            # ---- Bounding-box colour ----
            if   theft_status == TheftStatus.THEFT_CONFIRMED: color = COLOR_STOLEN
            elif theft_status == TheftStatus.TAKEN:           color = COLOR_DANGER
            elif theft_status == TheftStatus.PICKED_UP:       color = COLOR_WARNING
            elif is_locked:                                    color = COLOR_LOCKED
            elif class_name == 'person':                       color = COLOR_PERSON
            else:                                              color = COLOR_OBJECT

            x1, y1, x2, y2 = bbox
            cv2.rectangle(frame, (x1, y1), (x2, y2), color, 2)

            # Label
            parts = [f"ID:{obj_id}", class_name]
            if SHOW_CONFIDENCE:
                parts.append(f"{confidence:.2f}")
            if is_locked:
                parts.append("[LOCKED]")
            if origin == ObjectOrigin.SECURE_ZONE:
                parts.append("[STORE]")
            elif origin == ObjectOrigin.WITH_PERSON:
                parts.append("[PERSONAL]")
            if   theft_status == TheftStatus.PICKED_UP:       parts.append("[PICKED]")
            elif theft_status == TheftStatus.TAKEN:           parts.append("[TAKEN]")
            elif theft_status == TheftStatus.THEFT_CONFIRMED: parts.append("[STOLEN!]")

            label = " ".join(parts)
            (tw, th), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_SIMPLEX, 0.5, 1)
            cv2.rectangle(frame, (x1, y1 - th - 10), (x1 + tw, y1), color, -1)
            cv2.putText(frame, label, (x1, y1 - 5),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, COLOR_TEXT, 1)

        # ---- Draw zones ----
        if SHOW_ZONES:
            zone_manager.draw_zones(frame)

        # ---- Draw in-progress zone ----
        if drawing_zone and current_zone_points:
            zone_color = {
                ZoneType.SECURE:     COLOR_SECURE_ZONE,
                ZoneType.EXIT:       COLOR_EXIT_ZONE,
                ZoneType.RESTRICTED: COLOR_RESTRICTED_ZONE,
            }[current_zone_type]
            for i, pt in enumerate(current_zone_points):
                cv2.circle(frame, tuple(pt), 5, zone_color, -1)
                if i > 0:
                    cv2.line(frame, tuple(current_zone_points[i-1]),
                             tuple(pt), zone_color, 2)
            # Live line from last point to cursor
            if current_zone_points:
                cv2.line(frame, tuple(current_zone_points[-1]),
                         tuple(mouse_position), zone_color, 1)

        # ---- Alert banner ----
        if alert_active and time.time() - alert_time < 3.0:
            cv2.rectangle(frame, (0, 0), (image_width, 65), COLOR_DANGER, -1)
            cv2.putText(frame, f"🚨 {alert_message}", (10, 45),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.8, COLOR_TEXT, 2)
            if ENABLE_VISUAL_ALERT:
                overlay = frame.copy()
                cv2.rectangle(overlay, (0, 0), (image_width, image_height),
                              COLOR_DANGER, -1)
                cv2.addWeighted(overlay, 0.15, frame, 0.85, 0, frame)
        else:
            alert_active = False

        # ---- Statistics panel ----
        if SHOW_STATISTICS:
            store_items = sum(1 for o in tracked_objects.values()
                              if o['origin'] == ObjectOrigin.SECURE_ZONE)
            picked      = sum(1 for o in tracked_objects.values()
                              if o['theft_status'] == TheftStatus.PICKED_UP)
            taken       = sum(1 for o in tracked_objects.values()
                              if o['theft_status'] == TheftStatus.TAKEN)
            locked_cnt  = sum(1 for o in tracked_objects.values() if o['is_locked'])

            panel_y = image_height - 200
            cv2.rectangle(frame, (10, panel_y), (420, image_height - 10), (0, 0, 0), -1)
            cv2.rectangle(frame, (10, panel_y), (420, image_height - 10), COLOR_NORMAL, 1)

            stats = [
                f"Tracked:{len(tracked_objects)}  Store:{store_items}  Locked:{locked_cnt}",
                f"Picked:{picked}  Taken:{taken}",
                f"Thefts:{total_thefts}  Loiter:{total_loitering}  Restricted:{total_restricted}",
                f"Suspicious:{total_suspicious}  Protected:{total_protection}",
                f"Zones  S:{len(zone_manager.secure_zones)}"
                f"  E:{len(zone_manager.exit_zones)}"
                f"  R:{len(zone_manager.restricted_zones)}",
            ]
            y = panel_y + 28
            for text in stats:
                cv2.putText(frame, text, (18, y),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.45, COLOR_TEXT, 1)
                y += 32

        # ---- HUD instruction ----
        if drawing_zone:
            hud = (f"Drawing {current_zone_type.value.upper()} | "
                   f"Click to add points | Press key again to finish")
        else:
            hud = "o=Secure  e=Exit  z=Restrict  l=Lock  u=Unlock  c=Clear  s=Save  q=Quit"
        cv2.putText(frame, hud, (10, 20),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.45, COLOR_TEXT, 1)

        cv2.imshow('Ultimate Theft Detection System', frame)

        # ---- Keyboard handling ----
        key = cv2.waitKey(1) & 0xFF

        if key == ord('q'):
            print("\n⚠️  Shutting down …")
            break

        elif key == ord('o'):
            _toggle_zone(ZoneType.SECURE, "SECURE (green)")

        elif key == ord('e'):
            _toggle_zone(ZoneType.EXIT, "EXIT (red)")

        elif key == ord('z'):
            _toggle_zone(ZoneType.RESTRICTED, "RESTRICTED (magenta)")

        elif key == ord('l'):
            mx, my = mouse_position
            locked_any = False
            for obj_id, obj_data in tracked_objects.items():
                x1, y1, x2, y2 = obj_data['bbox']
                if x1 <= mx <= x2 and y1 <= my <= y2:
                    if tracker.lock_object(obj_id):
                        print(f"✓ Locked Object {obj_id} ({obj_data['class']})")
                        locked_any = True
                        break
            if not locked_any:
                print("⚠ No object under cursor — hover over an object first.")

        elif key == ord('u'):
            n = len(tracker.locked_objects)
            for oid in list(tracker.locked_objects.keys()):
                tracker.unlock_object(oid)
            print(f"✓ Unlocked {n} object(s)" if n else "⚠ No locked objects.")

        elif key == ord('c'):
            zone_manager.clear_zones()
            print("✓ All zones cleared")

        elif key == ord('s'):
            zone_manager.save_zones()

    # ---- Summary ----
    print("\n" + "=" * 60)
    print("SESSION SUMMARY")
    print("=" * 60)
    print(f"Frames processed : {frame_count}")
    print(f"Thefts           : {total_thefts}")
    print(f"Loitering        : {total_loitering}")
    print(f"Restricted zone  : {total_restricted}")
    print(f"Suspicious       : {total_suspicious}")
    print(f"Protected missing: {total_protection}")
    print(f"Events logged    : {len(theft_detector.theft_events)}")
    print("=" * 60)

    camera.release()
    cv2.destroyAllWindows()
    print("✅ System closed\n")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n⚠️  Interrupted by user")
        cv2.destroyAllWindows()
    except Exception as exc:
        import traceback
        print(f"\n❌ Unexpected error: {exc}")
        traceback.print_exc()
        cv2.destroyAllWindows()
