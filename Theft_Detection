class ZoneManager:
    """Manages secure, exit, and restricted zones."""

    def __init__(self, zone_file=ZONE_FILE):
        self.secure_zones     = []
        self.exit_zones       = []
        self.restricted_zones = []
        self.zone_file        = zone_file
        self.load_zones()

    def add_zone(self, points, zone_type):
        if zone_type == ZoneType.SECURE:
            self.secure_zones.append(points)
        elif zone_type == ZoneType.EXIT:
            self.exit_zones.append(points)
        elif zone_type == ZoneType.RESTRICTED:
            self.restricted_zones.append(points)

    def clear_zones(self):
        self.secure_zones     = []
        self.exit_zones       = []
        self.restricted_zones = []

    def save_zones(self):
        dir_ = os.path.dirname(self.zone_file)
        if dir_:
            os.makedirs(dir_, exist_ok=True)
        with open(self.zone_file, 'w') as f:
            json.dump({
                'secure_zones':     self.secure_zones,
                'exit_zones':       self.exit_zones,
                'restricted_zones': self.restricted_zones,
            }, f)
        print(f"✓ Zones saved — secure:{len(self.secure_zones)}  "
              f"exit:{len(self.exit_zones)}  restricted:{len(self.restricted_zones)}")

    def load_zones(self):
        if not os.path.exists(self.zone_file):
            return
        try:
            with open(self.zone_file) as f:
                data = json.load(f)
            self.secure_zones     = data.get('secure_zones',     [])
            self.exit_zones       = data.get('exit_zones',       [])
            self.restricted_zones = data.get('restricted_zones', [])
            total = len(self.secure_zones) + len(self.exit_zones) + len(self.restricted_zones)
            if total:
                print(f"✓ Loaded {total} zone(s)")
        except Exception as exc:
            print(f"⚠ Could not load zones: {exc}")

    # ------------------------------------------------------------------
    @staticmethod
    def point_in_polygon(point, polygon):
        """Ray-casting algorithm."""
        x, y  = point
        n     = len(polygon)
        inside= False
        p1x, p1y = polygon[0]
        for i in range(1, n + 1):
            p2x, p2y = polygon[i % n]
            if y > min(p1y, p2y):
                if y <= max(p1y, p2y):
                    if x <= max(p1x, p2x):
                        if p1y != p2y:
                            xinters = (y - p1y) * (p2x - p1x) / (p2y - p1y) + p1x
                        if p1x == p2x or x <= xinters:
                            inside = not inside
            p1x, p1y = p2x, p2y
        return inside

    def check_in_secure_zone(self, centroid):
        for i, zone in enumerate(self.secure_zones):
            if len(zone) >= 3 and self.point_in_polygon(centroid, zone):
                return True, i
        return False, None

    def check_in_exit_zone(self, centroid):
        for i, zone in enumerate(self.exit_zones):
            if len(zone) >= 3 and self.point_in_polygon(centroid, zone):
                return True, i
        return False, None

    def check_in_restricted_zone(self, centroid):
        for i, zone in enumerate(self.restricted_zones):
            if len(zone) >= 3 and self.point_in_polygon(centroid, zone):
                return True, i
        return False, None

    # ------------------------------------------------------------------
    def draw_zones(self, frame):
        configs = [
            (self.secure_zones,     COLOR_SECURE_ZONE,     "SECURE"),
            (self.exit_zones,       COLOR_EXIT_ZONE,        "EXIT"),
            (self.restricted_zones, COLOR_RESTRICTED_ZONE,  "RESTRICTED"),
        ]
        for zones, color, label in configs:
            for zone in zones:
                if len(zone) < 2:
                    continue
                pts     = np.array(zone, np.int32).reshape((-1, 1, 2))
                overlay = frame.copy()
                cv2.fillPoly(overlay, [pts], color)
                cv2.addWeighted(overlay, 0.2, frame, 0.8, 0, frame)
                cv2.polylines(frame, [pts], True, color, 2)
                cv2.putText(frame, label, tuple(zone[0]),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.5, color, 2)

